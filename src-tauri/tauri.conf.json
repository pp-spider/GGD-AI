{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GGD-AI",
  "version": "0.1.0",
  "identifier": "com.ggdai.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "鹅鸭杀发言监听助手",
        "width": 350,
        "height": 650,
        "minWidth": 350,
        "minHeight": 650,
        "maxWidth": 350,
        "maxHeight": 650,
        "resizable": false,
        "decorations": true,
        "transparent": true,
        "center": true,
        "alwaysOnTop": false,
        "visible": true
      }
    ],
    "security": {
      "csp": null,
      "capabilities": []
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
